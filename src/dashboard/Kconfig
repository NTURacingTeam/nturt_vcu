menuconfig VCU_DASHBOARD
	bool "Dashboard system"
	select LED
	select LED_STRIP
	select AUXDISPLAY
	select VCU_SYS
	select VCU_STATES
	select VCU_CTRL

if VCU_DASHBOARD

config VCU_DASHBOARD_INIT_PRIORITY
	int "Init priority"
	default 50
	help
	  Dashboard system initialization priority.

config VCU_DASHBOARD_SHELL
	bool "Dashboard shell support"
	depends on VCU_SHELL
	default y
	select LED_SHELL

config VCU_DASHBOARD_SETTINGS
	bool "Dashboard settings support"
	depends on SETTINGS
	default y

endif # VCU_DASHBOARD
